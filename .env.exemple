# Variables de la base de données
POSTGRES_USER=myuser
POSTGRES_DB=mydatabase
PG_TDE_KEYRING_FILE=/var/lib/postgresql/data/pg_tde_keyring.key
PGPORT=5432

# Variables pour SSL/mTLS
CERT_DIR=/etc/certs
DAYS_VALID=365

# Liste des noms de clients (séparés par des espaces)
CLIENT_NAMES="client_post_A client_post_B app_web_iis"

# Mot de passe pour les fichiers PFX (laisser vide pour aucun mot de passe)
PFX_PASSWORD=MonMotDePasseSecure
